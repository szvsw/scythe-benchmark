EXISTING_BUCKET=my-benchmark-bucket
HATCHET_CLIENT_TOKEN=ey12345

SIM_COUNT=256
FAN_COUNT=64

# Capacity type: "spot" or "on-demand"
CAPACITY=spot

AWS_ACCOUNT_ID=123456789012
AWS_REGION=us-east-1

# Set to "true" to use a prebuilt image from ECR (faster deploys).
# Requires running `make push-worker` first from the repo root.
USE_PREBUILT_IMAGE=true
IMAGE_TAG=latest
